# ---- Server ----
PORT=8080

# ---- Twitch App (from https://dev.twitch.tv/console/apps) ----
TWITCH_CLIENT_ID=your_client_id_here
TWITCH_CLIENT_SECRET=your_client_secret_here

# ---- Broadcaster ----
# Your channel's numeric Twitch user ID (get it from https://streamscharts.com/tools/convert-username
# or https://www.streamweasels.com/tools/convert-twitch-username-to-user-id/)
TWITCH_BROADCASTER_ID=your_numeric_user_id

# User access token for the broadcaster, generated once via the OAuth flow described
# in setup/twitch_setup.md. Needs the scope: channel:read:redemptions
TWITCH_USER_ACCESS_TOKEN=your_user_access_token
TWITCH_REFRESH_TOKEN=your_refresh_token

# No reward title to configure here — create as many Channel Points rewards as
# you want directly in the Twitch Creator Dashboard, at whatever price you
# like, each titled "Change Car" (no filter) or "Change Car: <word>" (one
# filter, e.g. "Change Car: Honda", "Change Car: Class A", "Change Car: RWD").
# See setup/twitch_setup.md.

# ---- Twitch Chat Bot (for !changecar commands) ----
# Can be your own account or a separate bot account. Get an oauth token
# (format: oauth:xxxxxxxx) from https://twitchtokengenerator.com (chat:read
# and chat:edit scopes) or via the OAuth flow in setup/twitch_setup.md.
TWITCH_BOT_USERNAME=your_bot_or_own_username
TWITCH_BOT_OAUTH_TOKEN=oauth:your_token_here
TWITCH_CHANNEL=your_channel_name

# Set to "true" to have the bot reply in chat with the car it picked.
TWITCH_CHAT_REPLY=true
